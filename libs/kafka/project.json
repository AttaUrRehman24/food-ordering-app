{
  "name": "@food-ordering/kafka",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/kafka/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:kafka"],
  "targets": {
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint 'libs/kafka/src/**/*.ts'"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/kafka/tsconfig.lib.json --noEmit"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --config libs/kafka/jest.config.ts --passWithNoTests"
      }
    }
  }
}
