{
  "name": "food-ordering",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": [
    "libs/*"
  ],
  "scripts": {
    "nx": "nx",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "serve:gateway": "nx serve gateway",
    "serve:identity": "nx serve identity",
    "serve:catalog": "nx serve catalog",
    "serve:cart": "nx serve cart",
    "serve:order": "nx serve order",
    "serve:notification": "nx serve notification",
    "serve:realtime": "nx serve realtime",
    "serve:web": "nx serve web",
    "infra:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "infra:observability": "docker compose -f infra/docker/docker-compose.yml -f infra/docker/docker-compose.observability.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.yml -f infra/docker/docker-compose.observability.yml down",
    "infra:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "load:catalog": "k6 run infra/load/catalog-read.js",
    "load:orders": "k6 run infra/load/order-burst.js",
    "load:flow": "node infra/load/order-flow-concurrency.mjs",
    "load:concurrency-report": "node infra/load/high-concurrency-report.mjs",
    "identity:migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/identity/src/infrastructure/persistence/typeorm.data-source.ts",
    "identity:migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/identity/src/infrastructure/persistence/typeorm.data-source.ts",
    "identity:migration:show": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:show -d apps/identity/src/infrastructure/persistence/typeorm.data-source.ts",
    "catalog:migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/catalog/src/infrastructure/persistence/typeorm.data-source.ts",
    "catalog:migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/catalog/src/infrastructure/persistence/typeorm.data-source.ts",
    "catalog:seed": "ts-node -r tsconfig-paths/register -P apps/catalog/tsconfig.app.json apps/catalog/src/infrastructure/persistence/run-seed.ts",
    "cart:migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/cart/src/infrastructure/persistence/typeorm.data-source.ts",
    "cart:migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/cart/src/infrastructure/persistence/typeorm.data-source.ts",
    "order:migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/order/src/infrastructure/persistence/typeorm.data-source.ts",
    "order:migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/order/src/infrastructure/persistence/typeorm.data-source.ts",
    "notification:migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/notification/src/infrastructure/persistence/typeorm.data-source.ts",
    "notification:migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/notification/src/infrastructure/persistence/typeorm.data-source.ts",
    "dev:up": "./scripts/dev-up.sh",
    "dev:stop": "./scripts/dev-up.sh stop",
    "dev:status": "./scripts/dev-up.sh status",
    "dev:infra": "./scripts/dev-up.sh infra"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1091.0",
    "@aws-sdk/s3-request-presigner": "^3.1091.0",
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "@nestjs/common": "^11.0.12",
    "@nestjs/core": "^11.0.12",
    "@nestjs/microservices": "^11.0.12",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/platform-ws": "^11.1.28",
    "@nestjs/swagger": "^11.1.1",
    "@nestjs/typeorm": "^11.0.3",
    "@nestjs/websockets": "^11.1.28",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/instrumentation": "^0.57.2",
    "@opentelemetry/instrumentation-http": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.2",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "http-proxy": "^1.18.1",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "next": "^15.2.4",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "typeorm": "^1.1.0",
    "uuid": "^14.0.1",
    "ws": "^8.21.1",
    "zod": "^3.24.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.0.12",
    "@nx/eslint": "20.8.0",
    "@nx/eslint-plugin": "20.8.0",
    "@nx/js": "20.8.0",
    "@nx/nest": "20.8.0",
    "@nx/next": "20.8.0",
    "@nx/node": "20.8.0",
    "@nx/webpack": "20.8.0",
    "@nx/workspace": "20.8.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/http-proxy": "^1.17.17",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nx": "20.8.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
