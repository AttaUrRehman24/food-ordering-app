# Local environment template ( Documentation §20 — .env.example complete).
# Copy to repo root as `.env` for local development. Never commit secrets.

NODE_ENV=development

# Shared datastore URLs (infra/docker/docker-compose.yml)
DATABASE_URL=postgres://food:food@localhost:5432/food_ordering
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=food-ordering-local

# TypeORM (Identity and all future services)
TYPEORM_LOGGING=false

# JWT TTLs ( Documentation §8 — access ~15m, refresh long-lived)
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# S3 / MinIO (Catalog media seam)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=food-ordering-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# CORS allowlist (Article III.6 — no * in production)
CORS_ORIGINS=http://localhost:3000

# Default admin seeder credentials (Identity — admin cannot register; Q2)
ADMIN_EMAIL=admin@foodordering.local
ADMIN_PASSWORD=ChangeMe_Admin_Seed_Only
ADMIN_PHONE=+10000000000
ADMIN_NAME=System Admin

# Catalog seed — food menu with PKR prices (CATALOG_SEED_RESET=true replaces old data)
CATALOG_SEED_PRODUCT_COUNT=36
CATALOG_SEED_BATCH_SIZE=50
CATALOG_SEED_ON_BOOT=false
CATALOG_SEED_RESET=true
S3_PUBLIC_BASE_URL=http://localhost:9000
S3_PRESIGN_EXPIRES_SECONDS=900

# Cart → Catalog gRPC (price lookup)
CATALOG_GRPC_URL=localhost:50052
CART_GRPC_URL=localhost:50053
ORDER_GRPC_URL=localhost:50054
IDENTITY_GRPC_URL=localhost:50051

# Gateway BFF (HTTP :3001) → Realtime WS proxy
REALTIME_WS_URL=http://localhost:3007
HTTP_PORT=3001

# Observability ( Documentation §12 — local OTel Collector)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SDK_DISABLED=false

# Gateway request size limit (§11)
REQUEST_BODY_LIMIT=64kb

# Next.js web (Article VII.1 — REST gateway only)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# JWT public key for Realtime WS auth (same key Identity signs with)
# JWT_PUBLIC_KEY_PATH=apps/identity/keys/jwt-public.pem

# Realtime WebSocket connection caps ( Documentation §10)
WS_MAX_CONNECTIONS_PER_USER=5
WS_MAX_CONNECTIONS_PER_IP=20

# Gmail SMTP for OTP / transactional email (Notification service)
# Use a Google App Password (not your normal Gmail password):
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FoodApp <noreply@gmail.com>"

# Gmail SMTP for OTP / transactional email (Notification service)
# Use a Google App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FoodApp <noreply@gmail.com>"
